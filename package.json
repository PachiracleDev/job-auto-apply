{
  "name": "job-applier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit && pnpm --filter job-applier-worker exec tsc --noEmit",
    "build": "tsc && tsc-alias",
    "worker": "bun server/src/index.ts",
    "worker:dev": "bun --watch server/src/index.ts",
    "worker:db:generate": "pnpm --filter job-applier-worker exec drizzle-kit generate",
    "worker:db:migrate": "pnpm --filter job-applier-worker exec drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.10.0",
    "@lancedb/lancedb": "^0.27.2",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.5",
    "openai": "^4.77.0",
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.51.0",
    "sharp": "^0.33.5",
    "sqlite-vec": "^0.1.9",
    "tslog": "^4.9.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
