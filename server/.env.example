# PostgreSQL (requerido para rutas que usan DB)
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# API key compartida con tu servidor principal (Authorization: Bearer … o X-API-Key)
WORKER_API_KEY=

# Clave AES-256: 32 bytes en base64 (ej. openssl rand -base64 32)
SESSION_ENCRYPTION_KEY=

# Puerto HTTP del worker
PORT=8787

# Playwright: false = ventana visible (útil para depurar búsqueda)
WORKER_HEADLESS=true

# Reutiliza el .env de la raíz del monorepo para OPENAI_*, BROWSER_PATH, DATA_DIR, etc.
#
# Arranque desde la raíz: pnpm worker | pnpm worker:dev (requiere Bun en PATH)
#
# Navegador headless en Docker (compose en la raíz): ver PLAYWRIGHT_WS_ENDPOINT en .env del repo
