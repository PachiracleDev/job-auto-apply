# Copia a .env y rellena los valores

# Requerido solo si CV_TAILOR_WITH_AI o COVER_LETTER_WITH_AI están en true
ANTHROPIC_API_KEY=

# Personalizar CV con Claude (requiere ANTHROPIC_API_KEY). Si es false, se usa DEFAULT_CV_PDF.
CV_TAILOR_WITH_AI=false

# Carta de presentación con Claude (requiere ANTHROPIC_API_KEY). Si es false, se usa un texto genérico en el zip.
COVER_LETTER_WITH_AI=false

# PDF base cuando CV_TAILOR_WITH_AI=false (ruta relativa al directorio del proyecto)
DEFAULT_CV_PDF=./cv/CV - ES.pdf

# Directorios (por defecto: ./data y ./output)
DATA_DIR=./data
OUTPUT_DIR=./output

# Opcional: ejecutable de Chrome (si LinkedIn rechaza el lanzado por Playwright).
# Windows ejemplo:
# BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# BROWSER_PATH=

# Navegador remoto (Docker): `docker compose up playwright-browser` y conexión por WebSocket
# (protocolo Playwright, no CDP crudo). Debe coincidir la versión con playwright-core del lockfile.
# PLAYWRIGHT_WS_ENDPOINT=ws://127.0.0.1:9222/

# Opcional: nivel de log (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Modo simulación (también se puede pasar --dry-run al CLI)
DRY_RUN=false

# collect: si true, solo guarda ofertas si se detecta el botón en la ficha (puede dejar el JSON vacío).
# Recomendado: false o comentado (confía en f_AL y usa easyApplyVerifiedOnPage en el JSON).
COLLECT_REQUIRE_EASY_APPLY_BUTTON=false

# OpenAI (opcional): parseo en collect y relleno del modal Easy Apply en `pnpm apply`
OPENAI_API_KEY=
COLLECT_OPENAI_MODEL=gpt-4o-mini
# APPLY_OPENAI_MODEL=gpt-4o-mini
# APPLY_USE_OPENAI_FORM= (vacío = usar IA si OPENAI_API_KEY está definida; false = solo heurísticas)

# --- Worker HTTP (pnpm worker) — ver también server/.env.example ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# WORKER_API_KEY=
# SESSION_ENCRYPTION_KEY=
# PORT=8787
# WORKER_HEADLESS=true
