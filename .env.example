# Copia a .env y rellena los valores

# Requerido para `pnpm run` (Claude). Opcional solo para login/check-session/clear.
ANTHROPIC_API_KEY=

# Directorios (por defecto: ./data y ./output)
DATA_DIR=./data
OUTPUT_DIR=./output

# Opcional: ruta al ejecutable de Chromium/Chrome para Playwright
# BROWSER_PATH=

# Opcional: nivel de log (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Modo simulación (también se puede pasar --dry-run al CLI)
DRY_RUN=false
